{% extends 'base.html.twig' %}
{% set active = 'entreprises' %}

{% block title %}StageHub — Entreprises partenaires{% endblock %}
{% block meta_desc %}Découvrez toutes les entreprises partenaires de StageHub et leurs offres de stage.{% endblock %}

{% block content %}

<div class="page-header">
  <div class="page-header-inner">
    <div class="breadcrumb">
      <a href="/">Accueil</a>
      <span>›</span>
      <span class="current">Entreprises</span>
    </div>

    <h1>Nos <em>entreprises</em> partenaires</h1>
    <p>{{ stats.total_entreprises ?? 0 }} entreprises proposent des offres de stage sur StageHub</p>

    <form action="/entreprises" method="GET"
          class="search-bar" style="max-width: 560px; margin: 0 auto">
      <input
        class="search-input"
        type="text"
        name="q"
        placeholder="Rechercher une entreprise…"
        id="searchInput"
        value="{{ app_query ?? '' }}"
      />
      <button class="search-btn" type="submit">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>
    </form>
  </div>
</div>

<div class="layout">

  <button class="filter-toggle-btn" id="filterToggle">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <line x1="4"  y1="6"  x2="20" y2="6"/>
      <line x1="8"  y1="12" x2="16" y2="12"/>
      <line x1="10" y1="18" x2="14" y2="18"/>
    </svg>
    Filtres
  </button>

  <aside class="sidebar" id="sidebar" style="width: 240px">
    <form id="filterForm" action="/entreprises" method="GET">
      <input type="hidden" name="q" value="{{ app_query ?? '' }}"/>

      {# Note minimale #}
      <div class="filter-card">
        <h3>Note minimale</h3>
        <div class="stars-filter">
          {% set notes = [
            { value: '0', label: 'Toutes'      },
            { value: '3', label: '3 et plus'   },
            { value: '4', label: '4 et plus'   },
            { value: '5', label: '5 seulement' },
          ] %}
          {% for n in notes %}
            <label class="star-row">
              <input type="radio" name="note_min" value="{{ n.value }}"
                     {{ (app_note_min ?? 0) == n.value ? 'checked' }}
                     onchange="this.form.submit()"/>
              <span class="stars">
                {%- for i in 1..5 -%}
                  {{- n.value > 0 and i <= n.value ? '★' : '☆' -}}
                {%- endfor -%}
              </span>
              <span class="count">{{ n.label }}</span>
            </label>
          {% endfor %}
        </div>
      </div>

      {# Offres actives #}
      <div class="filter-card">
        <h3>Offres actives</h3>
        <div class="filter-options">
          {% set ranges = [
            { value: '1-5',  label: '1 – 5 offres'  },
            { value: '6-10', label: '6 – 10 offres'  },
            { value: '10+',  label: '10+ offres'     },
          ] %}
          {% for r in ranges %}
            <label class="filter-option">
              <input type="radio" name="offres_range" value="{{ r.value }}"
                     {{ (app_offres_range ?? '') == r.value ? 'checked' }}
                     onchange="this.form.submit()"/>
              <span class="custom-check">
                <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5">
                  <polyline points="1.5,6 5,9.5 10.5,2.5"/>
                </svg>
              </span>
              <span class="filter-label">{{ r.label }}</span>
            </label>
          {% endfor %}
        </div>
      </div>

      <button type="submit" class="apply-btn">Appliquer</button>
      <a href="/entreprises" class="apply-btn"
         style="display:block;text-align:center;margin-top:8px;background:#eee;color:#333">
        Réinitialiser
      </a>
    </form>
  </aside>

  <div class="main-content">

    <div class="results-bar">
      <p class="results-count" id="resultsCount">
        <strong>{{ stats.total_entreprises ?? 0 }} entreprises</strong> référencées
      </p>
      <div class="sort-wrap">
        <span class="sort-label">Trier par</span>
        <select class="sort-select">
          <option>Meilleures notes</option>
          <option>Plus d'offres</option>
          <option>Nom A–Z</option>
        </select>
      </div>
    </div>

    {# Chips filtres actifs #}
    <div class="active-filters">
      {% if app_note_min is defined and app_note_min > 0 %}
        <a href="?q={{ app_query }}&offres_range={{ app_offres_range }}" class="chip">
          Note {{ app_note_min }}+ <span class="chip-x">×</span>
        </a>
      {% endif %}
      {% if app_offres_range is defined and app_offres_range != '' %}
        <a href="?q={{ app_query }}&note_min={{ app_note_min }}" class="chip">
          {{ app_offres_range }} offres <span class="chip-x">×</span>
        </a>
      {% endif %}
    </div>

    <div class="company-grid" id="companyGrid">
      {% for e in entreprises %}
        <a href="/entreprises/{{ e.id_entreprise }}" class="company-card">
          <div class="company-logo-wrap">{{ e.name|slice(0,2)|upper }}</div>
          <p class="company-card-name">{{ e.name }}</p>
          <p class="company-sector">{{ e.ville }}{% if e.region %}, {{ e.region }}{% endif %}</p>
          <div class="company-stars">
            {%- set note = e.note_moyenne ?? 0 -%}
            {%- for i in 1..5 -%}
              {{- note >= i ? '★' : '☆' -}}
            {%- endfor -%}
            <span style="font-size:.8rem;color:#999;margin-left:4px">({{ note ?? '—' }})</span>
          </div>
          <div class="company-meta">
            {% if e.description %}
              <span class="meta-tag">{{ e.description|slice(0,40) }}…</span>
            {% endif %}
          </div>
          <p class="company-offers-count">{{ e.nb_offres ?? 0 }} offres actives</p>
          <span class="btn-see">Voir les offres</span>
        </a>
      {% else %}
        <p style="color:#999; grid-column:1/-1; text-align:center; padding:60px 0">
          Aucune entreprise ne correspond à votre recherche.
        </p>
      {% endfor %}
    </div>

    {% if pagination is defined and pagination.total_pages > 1 %}
      <div class="pagination">
        
        {% if pagination.current > 1 %}
        <a href="?page={{ pagination.current - 1 }}&q={{ app_query }}&note_min={{ app_note_min }}&offres_range={{ app_offres_range }}"
           class="page-btn arrow">‹</a>
        {% endif %}

        {% for p in 1..pagination.total_pages %}
          {% if p == pagination.current %}
            <button class="page-btn active">{{ p }}</button>
          {% elseif p <= 4 or p == pagination.total_pages %}
            <a href="?page={{ p }}&q={{ app_query }}&note_min={{ app_note_min }}&offres_range={{ app_offres_range }}"
               class="page-btn">{{ p }}</a>
          {% elseif p == 5 %}
            <span style="font-weight:700;color:#ccc;padding:0 4px">…</span>
          {% endif %}
        {% endfor %}

        
        {% if pagination.current < pagination.total_pages %}
        <a href="?page={{ pagination.current + 1 }}&q={{ app_query }}&note_min={{ app_note_min }}&offres_range={{ app_offres_range }}"
           class="page-btn arrow">›</a>
        {% endif %}
      </div>

    {% endif %}

  </div>

</div>

{% endblock %}

{% block extra_js %}
<script src="/assets/js/entreprises-script.js"></script>
{% endblock %}