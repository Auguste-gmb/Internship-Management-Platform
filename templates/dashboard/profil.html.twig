{% extends 'base.html.twig' %}
{% set active = 'dashboard' %}

{% block title %}StageHub — Mon profil{% endblock %}
{% block meta_desc %}Mon profil — StageHub{% endblock %}

{% block extra_css %}
<link rel="stylesheet" href="/assets/css/pages-extra.css"/>
{% endblock %}

{% block content %}

<div class="page-profil">
  <div class="profil-hero">
    <div class="profil-avatar-big avatar-upload" title="Changer la photo">
      <span id="avatarInitials">{{ user.prenom|slice(0,1)|upper }}{{ user.nom|slice(0,1)|upper }}</span>
      <input type="file" accept="image/*" onchange="handleAvatar(this)"/>
      <div class="avatar-upload-overlay">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
          <circle cx="12" cy="13" r="4"/>
        </svg>
        <span style="font-size:.65rem">Modifier</span>
      </div>
    </div>
    <div class="profil-hero-info">
      <h1 id="heroName">{{ user.prenom }} {{ user.nom }}</h1>
      <p id="heroEmail">{{ user.email }}</p>
      <span class="profil-promo-badge">{{ user.promo ?? 'PGE A2 · CPI INFO' }}</span>
      <div style="display:flex;gap:24px;margin-top:16px;flex-wrap:wrap">
        <div>
          <span style="font-weight:900;font-size:1.3rem;color:var(--salmon)">{{ stats.candidatures }}</span>
          <span style="color:var(--gray);font-size:.82rem;font-weight:700;margin-left:6px">Postulés</span>
        </div>
        <div>
          <span style="font-weight:900;font-size:1.3rem;color:var(--salmon)">{{ stats.wishlist }}</span>
          <span style="color:var(--gray);font-size:.82rem;font-weight:700;margin-left:6px">Wish-list</span>
        </div>
      </div>
    </div>
    <div style="display:flex;flex-direction:column;gap:8px;flex-shrink:0">
      <a href="/dashboard" class="btn-login" style="text-align:center">← Dashboard</a>
      <a href="/dashboard/candidatures" class="btn-login" style="text-align:center">Candidatures</a>
      <a href="/dashboard/wishlist" class="btn-login" style="text-align:center">Wish-list</a>
    </div>
  </div>

  <div class="profil-grid">
    <div class="profil-card">
      <h2>Informations personnelles</h2>
      <form method="POST" action="/dashboard/profil/update">
        <div class="profil-field">
          <label class="profil-label">Prénom</label>
          <input class="profil-input" type="text" name="prenom" value="{{ user.prenom }}"/>
        </div>
        <div class="profil-field">
          <label class="profil-label">Nom</label>
          <input class="profil-input" type="text" name="nom" value="{{ user.nom }}"/>
        </div>
        <div class="profil-field">
          <label class="profil-label">Email</label>
          <input class="profil-input" type="email" name="email" value="{{ user.email }}"/>
        </div>
        <div class="profil-field">
          <label class="profil-label">Téléphone</label>
          <input class="profil-input" type="tel" name="telephone" value="{{ user.telephone ?? '' }}" placeholder="06 00 00 00 00"/>
        </div>
        <button type="submit" class="btn-save">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px">
            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
            <polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/>
          </svg>
          Sauvegarder
        </button>
      </form>
    </div>

    <div class="profil-card">
      <h2>Sécurité</h2>
      <form method="POST" action="/dashboard/profil/password">
        <div class="profil-field">
          <label class="profil-label">Mot de passe actuel</label>
          <input class="profil-input" type="password" name="current_password" placeholder="••••••••"/>
        </div>
        <div class="profil-field">
          <label class="profil-label">Nouveau mot de passe</label>
          <input class="profil-input" type="password" name="new_password" placeholder="••••••••"/>
        </div>
        <div class="profil-field">
          <label class="profil-label">Confirmer le mot de passe</label>
          <input class="profil-input" type="password" name="confirm_password" placeholder="••••••••"/>
        </div>
        <button type="submit" class="btn-save" style="background:var(--dark)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px">
            <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          Modifier le mot de passe
        </button>
      </form>
    </div>
  </div>
</div>

<div class="toast-container" id="toastContainer"></div>

{% endblock %}

{% block extra_js %}
<script src="/assets/js/profil-script.js"></script>
{% endblock %}