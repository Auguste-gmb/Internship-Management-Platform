{% extends 'base.html.twig' %}
{% set active = 'dashboard' %}

{% block title %}StageHub Admin — Utilisateurs{% endblock %}
{% block meta_desc %}Gestion des utilisateurs — StageHub{% endblock %}

{% block extra_css %}
<link rel="stylesheet" href="/assets/css/pages-extra.css"/>
{% endblock %}

{% block content %}

<div class="admin-layout">

  {# Sidebar #}
  <aside class="admin-sidebar">
    <div style="padding:20px 20px 4px">
      <span style="font-size:.72rem;font-weight:800;color:rgba(255,255,255,.35);text-transform:uppercase;letter-spacing:.1em">
        Administration
      </span>
    </div>
    <div class="admin-nav-section">Tableau de bord</div>
    <a href="/dashboard" class="admin-nav-link">Statistiques</a>

    <div class="admin-nav-section">Gestion</div>
    <a href="/dashboard/users" class="admin-nav-link active">Utilisateurs</a>
    <a href="/dashboard/entreprises" class="admin-nav-link">Entreprises</a>
    <a href="/dashboard/offres" class="admin-nav-link">Offres de stage</a>

    <div class="admin-nav-section">Compte</div>
    <a href="/profil" class="admin-nav-link">Mon profil</a>
    <a href="/logout" class="admin-nav-link">Déconnexion</a>
  </aside>

  {# Main content #}
  <main class="admin-main">

    <div class="admin-stats-row">
      <div class="admin-stat"><div class="admin-stat-icon blue">🎓</div><div><div class="admin-stat-val">{{ stats.etudiants ?? 0 }}</div><div class="admin-stat-lbl">Étudiants</div></div></div>
      <div class="admin-stat"><div class="admin-stat-icon green">👨‍🏫</div><div><div class="admin-stat-val">{{ stats.pilotes ?? 0 }}</div><div class="admin-stat-lbl">Pilotes</div></div></div>
      <div class="admin-stat"><div class="admin-stat-icon orange">🏢</div><div><div class="admin-stat-val">{{ stats.entreprises ?? 0 }}</div><div class="admin-stat-lbl">Entreprises</div></div></div>
      <div class="admin-stat"><div class="admin-stat-icon red">🛡️</div><div><div class="admin-stat-val">{{ stats.admins ?? 0 }}</div><div class="admin-stat-lbl">Admins</div></div></div>
    </div>

    <div class="admin-card">
      <div class="admin-card-header">
        <h2>Tous les utilisateurs</h2>
        <div class="admin-toolbar">
          <div class="admin-search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" placeholder="Rechercher…" id="userSearch" oninput="filterUsers()"/>
          </div>
          <select id="roleFilter" onchange="filterUsers()" style="border:1.5px solid #ddd;border-radius:50px;padding:8px 16px;font-family:var(--font);font-size:.85rem;font-weight:700;background:var(--white);outline:none">
            <option value="all">Tous les rôles</option>
            <option value="etudiant">Étudiants</option>
            <option value="pilote">Pilotes</option>
            <option value="admin">Admins</option>
            <option value="entreprise">Entreprises</option>
          </select>
          <button class="btn-admin-action" onclick="openCreateModal()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Ajouter
          </button>
        </div>
      </div>

      <table class="admin-table">
        <thead>
          <tr><th>Utilisateur</th><th>Email</th><th>Rôle</th><th>Promotion</th><th>Inscription</th><th>Actions</th></tr>
        </thead>
        <tbody id="usersBody">
          {% for user in users %}
            <tr>
              <td>{{ user.prenom }} {{ user.nom }}</td>
              <td>{{ user.email }}</td>
              <td>{{ user.role }}</td>
              <td>{{ user.promo }}</td>
              <td>{{ user.inscription|date('d/m/Y') }}</td>
              <td>
                <button onclick="editUser({{ user.id }})">✏️</button>
                <button onclick="deleteUser({{ user.id }})">🗑️</button>
              </td>
            </tr>
          {% else %}
            <tr><td colspan="6" style="text-align:center;color:#bbb;">Aucun utilisateur</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

  </main>
</div>

{% endblock %}

{% block extra_js %}
<script src="/assets/js/admin-users-script.js"></script>
<script>
document.getElementById('hamburger').addEventListener('click', () => {
  document.getElementById('hamburger').classList.toggle('open');
  document.getElementById('navLinks').classList.toggle('open');
});
</script>
{% endblock %}