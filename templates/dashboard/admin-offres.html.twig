{% extends 'base.html.twig' %}
{% set active = 'dashboard' %}

{% block title %}StageHub Admin — Offres{% endblock %}

{% block extra_css %}
<link rel="stylesheet" href="/assets/css/pages-extra.css"/>
{% endblock %}

{% block content %}
<div class="admin-layout">

  <aside class="admin-sidebar">
    <div style="padding:20px 20px 4px">
      <span style="font-size:.72rem;font-weight:800;color:rgba(255,255,255,.35);text-transform:uppercase;letter-spacing:.1em">
        Administration
      </span>
    </div>
    <div class="admin-nav-section">Tableau de bord</div>
    <a href="/dashboard" class="admin-nav-link">Statistiques</a>
    <div class="admin-nav-section">Gestion</div>
    <a href="/dashboard/users" class="admin-nav-link">Utilisateurs</a>
    <a href="/dashboard/entreprises" class="admin-nav-link">Entreprises</a>
    <a href="/dashboard/offres" class="admin-nav-link active">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
      </svg>
      Offres de stage
    </a>
    <div class="admin-nav-section">Compte</div>
    <a href="/profil" class="admin-nav-link">Mon profil</a>
    <a href="/deconnexion" class="admin-nav-link">Déconnexion</a>
  </aside>

  <main class="admin-main">
    <div class="admin-stats-row">
      <div class="admin-stat">
        <div class="admin-stat-icon blue">📋</div>
        <div>
          <div class="admin-stat-val">{{ stats.total ?? 0 }}</div>
          <div class="admin-stat-lbl">Total offres</div>
        </div>
      </div>
    </div>

    <div class="admin-card">
      <div class="admin-card-header">
        <h2>Toutes les offres de stage</h2>
        <div class="admin-toolbar">
          <div class="admin-search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="text" placeholder="Rechercher…" id="offerSearch" oninput="filterOffers()"/>
          </div>
          <a href="/offres/create" class="btn-admin-action">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px">
              <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Nouvelle offre
          </a>
        </div>
      </div>

      <table class="admin-table">
        <thead>
          <tr>
            <th>Intitulé</th>
            <th>Entreprise</th>
            <th>Domaine</th>
            <th>Durée</th>
            <th>Rémunération</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="offersBody">
          {% for offre in offres %}
            <tr>
              <td>{{ offre.title }}</td>
              <td>{{ offre.entreprise ?? '—' }}</td>
              <td>{{ offre.domain ?? '—' }}</td>
              <td>{{ offre.duration ?? '—' }}</td>
              <td>{{ offre.remuneration ?? '—' }}</td>
              <td style="display:flex; gap:8px;">
                <a href="/offres/{{ offre.id_offer }}/edit"
                   style="padding:6px 12px; background:#2563eb; color:#fff; border-radius:6px; text-decoration:none; font-size:.85rem;">
                  ✏️ Modifier
                </a>
                <form action="/offres/{{ offre.id_offer }}/delete" method="POST"
                      onsubmit="return confirm('Supprimer cette offre et toutes ses candidatures ?')">
                  <button type="submit"
                          style="padding:6px 12px; background:#e53e3e; color:#fff; border-radius:6px; border:none; cursor:pointer; font-size:.85rem;">
                    🗑️ Supprimer
                  </button>
                </form>
              </td>
            </tr>
          {% else %}
            <tr><td colspan="6">Aucune offre trouvée</td></tr>
          {% endfor %}
        </tbody>
      </table>

      {% if pagination.total_pages > 1 %}
      <div class="admin-pagination">
        {% if pagination.current > 1 %}
          <a class="page-btn arrow" href="?page={{ pagination.current - 1 }}">‹</a>
        {% endif %}
        {% for p in 1..pagination.total_pages %}
          <a class="page-btn {{ p == pagination.current ? 'active' : '' }}" href="?page={{ p }}">{{ p }}</a>
        {% endfor %}
        {% if pagination.current < pagination.total_pages %}
          <a class="page-btn arrow" href="?page={{ pagination.current + 1 }}">›</a>
        {% endif %}
      </div>
      {% endif %}

    </div>
  </main>
</div>
{% endblock %}

{% block extra_js %}
<script>
document.getElementById('hamburger').addEventListener('click', () => {
  document.getElementById('hamburger').classList.toggle('open');
  document.getElementById('navLinks').classList.toggle('open');
});

function filterOffers() {
  const q = document.getElementById('offerSearch').value.toLowerCase();
  document.querySelectorAll('#offersBody tr').forEach(row => {
    row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
}
</script>
{% endblock %}