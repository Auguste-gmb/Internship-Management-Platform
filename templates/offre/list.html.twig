{% extends 'base.html.twig' %}
{% set active = 'offres' %}

{% block title %}StageHub — Offres de stage{% endblock %}
{% block meta_desc %}Parcourez toutes les offres de stage disponibles sur StageHub.{% endblock %}

{% block content %}

{# ════ PAGE HEADER ══════════════════════════════════════════════════════════ #}
<div class="page-header">
  <div class="page-header-inner">

    <div class="breadcrumb">
      <a href="/">Accueil</a>
      <span>›</span>
      <span class="current">Offres</span>
    </div>

    <h1>Toutes les <em>offres</em> de stage</h1>
    <p>{{ stats.total_offres ?? 128 }} offres disponibles dans {{ stats.total_entreprises ?? 80 }} entreprises partenaires</p>

    <div class="search-wrap">
      <form class="search-bar" action="/offres" method="GET">
        <input
          class="search-input"
          type="text"
          name="q"
          placeholder="Emploi, compétence..."
          id="jobInput"
          value="{{ app_query ?? '' }}"
        />
        <div class="search-divider"></div>
        <input
          class="search-input"
          type="text"
          name="loc"
          placeholder="Ville, région…"
          id="locInput"
          style="max-width: 200px"
          value="{{ app_loc ?? '' }}"
        />
        <button class="search-btn" type="submit" aria-label="Rechercher">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/>
            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>
      </form>
    </div>

  </div>
</div>

{# ════ LAYOUT ═══════════════════════════════════════════════════════════════ #}
<div class="layout">

  {# ── Bouton filtres mobile ──────────────────────────────────────────────── #}
  <button class="filter-toggle-btn" id="filterToggle">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <line x1="4"  y1="6"  x2="20" y2="6"/>
      <line x1="8"  y1="12" x2="16" y2="12"/>
      <line x1="10" y1="18" x2="14" y2="18"/>
    </svg>
    Filtres
  </button>

  {# ── SIDEBAR FILTRES ────────────────────────────────────────────────────── #}
  <aside class="sidebar" id="sidebar">

    {# Domaine #}
    <div class="filter-card">
      <h3>Domaine <button onclick="clearFilter('domaine')">Réinitialiser</button></h3>
      <div class="filter-options" id="domaine">
        {% set domaines = [
          { label: 'Informatique', count: 42, checked: true  },
          { label: 'Finance',      count: 18, checked: false },
          { label: 'Marketing',    count: 24, checked: false },
          { label: 'Design',       count: 16, checked: false },
          { label: 'Data / IA',    count: 28, checked: false },
        ] %}
        {% for d in domaines %}
          <label class="filter-option">
            <input type="checkbox" {{ d.checked ? 'checked' }} onchange="updateChips()"/>
            <span class="custom-check">
              <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="1.5,6 5,9.5 10.5,2.5"/>
              </svg>
            </span>
            <span class="filter-label">
              {{ d.label }}
              <span class="filter-count">{{ d.count }}</span>
            </span>
          </label>
        {% endfor %}
      </div>
    </div>

    {# Durée #}
    <div class="filter-card">
      <h3>Durée <button onclick="clearFilter('duree')">Réinitialiser</button></h3>
      <div class="filter-options" id="duree">
        {% set durees = [
          { label: '1 – 2 mois', count: 14, checked: false },
          { label: '3 – 4 mois', count: 52, checked: true  },
          { label: '5 – 6 mois', count: 62, checked: false },
        ] %}
        {% for d in durees %}
          <label class="filter-option">
            <input type="checkbox" {{ d.checked ? 'checked' }} onchange="updateChips()"/>
            <span class="custom-check">
              <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="1.5,6 5,9.5 10.5,2.5"/>
              </svg>
            </span>
            <span class="filter-label">
              {{ d.label }}
              <span class="filter-count">{{ d.count }}</span>
            </span>
          </label>
        {% endfor %}
      </div>
    </div>

    {# Rémunération #}
    <div class="filter-card">
      <h3>Rémunération</h3>
      <div class="range-wrap">
        <div class="range-display">
          <span>0 €</span>
          <span id="rangeVal">1 200 €/mois</span>
        </div>
        <input type="range" min="0" max="1500" value="1200"
               id="salaryRange" oninput="updateRange(this.value)"/>
      </div>
    </div>

    <button class="apply-btn" onclick="applyFilters()">Appliquer les filtres</button>
  </aside>

  {# ── CONTENU PRINCIPAL ──────────────────────────────────────────────────── #}
  <div class="main-content">

    <div class="results-bar">
      <p class="results-count">
        <strong>{{ offres|length }} offres</strong> correspondent à votre recherche
      </p>
      <div class="sort-wrap">
        <span class="sort-label">Trier par</span>
        <select class="sort-select" onchange="this.form && this.form.submit()">
          <option>Plus récentes</option>
          <option>Rémunération ↑</option>
          <option>Rémunération ↓</option>
          <option>Entreprise A–Z</option>
        </select>
      </div>
    </div>

    {# Chips filtres actifs #}
    <div class="active-filters" id="activeFilters">
      <button class="chip" onclick="removeChip(this)">
        Informatique <span class="chip-x">×</span>
      </button>
      <button class="chip" onclick="removeChip(this)">
        3 – 4 mois <span class="chip-x">×</span>
      </button>
    </div>

    {# ── Grille des offres ──────────────────────────────────────────────── #}
    <div class="offers-grid">
      {% for offre in offres %}
        <article class="offer-card" data-domain="{{ offre.domaine|lower }}">

          <span class="domain-badge">{{ offre.domaine }}</span>

          <div class="offer-top">
            <div class="offer-company">
              <div class="company-logo">{{ offre.entreprise|slice(0,2)|upper }}</div>
              <span class="company-name">{{ offre.entreprise }}</span>
            </div>
          </div>

          <p class="offer-title">{{ offre.titre }}</p>

          <div class="offer-location">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
            {{ offre.ville }}
          </div>

          <div class="offer-tags">
            {% for tag in offre.tags %}
              <span class="offer-tag">{{ tag }}</span>
            {% endfor %}
          </div>

          <div class="offer-footer">
            <span class="offer-salary">{{ offre.salaire }}</span>
            <span class="offer-date">{{ offre.date }}</span>
            <a href="/offres/{{ offre.id }}" class="btn-voir">Voir</a>
            <button class="wishlist-btn" onclick="toggleWish(this)" aria-label="Favoris">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </button>
          </div>

        </article>
      {% else %}
        <p style="color:#999; grid-column:1/-1; text-align:center; padding:60px 0">
          Aucune offre ne correspond à votre recherche.
        </p>
      {% endfor %}
    </div>

    {# ── Pagination ─────────────────────────────────────────────────────── #}
    {% if pagination is defined and pagination.total_pages > 1 %}
      <div class="pagination">
        <a href="?page={{ pagination.current - 1 }}"
           class="page-btn arrow {{ pagination.current <= 1 ? 'disabled' }}">‹</a>

        {% for p in 1..pagination.total_pages %}
          {% if p == pagination.current %}
            <button class="page-btn active">{{ p }}</button>
          {% elseif p <= 4 or p == pagination.total_pages %}
            <a href="?page={{ p }}" class="page-btn">{{ p }}</a>
          {% elseif p == 5 %}
            <span style="font-weight:700;color:#ccc;padding:0 4px">…</span>
          {% endif %}
        {% endfor %}

        <a href="?page={{ pagination.current + 1 }}"
           class="page-btn arrow {{ pagination.current >= pagination.total_pages ? 'disabled' }}">›</a>
      </div>
    {% else %}
      {# Pagination statique tant que la BDD n'est pas branchée #}
      <div class="pagination">
        <button class="page-btn arrow">‹</button>
        <button class="page-btn active">1</button>
        <button class="page-btn">2</button>
        <button class="page-btn">3</button>
        <button class="page-btn">4</button>
        <span style="font-weight:700;color:#ccc;padding:0 4px">…</span>
        <button class="page-btn">11</button>
        <button class="page-btn arrow">›</button>
      </div>
    {% endif %}

  </div>{# /main-content #}

</div>{# /layout #}

{% endblock %}

{% block extra_js %}
<script src="/assets/js/offer-script.js"></script>
{% endblock %}
