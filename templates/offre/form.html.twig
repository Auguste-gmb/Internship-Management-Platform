{% extends 'base.html.twig' %}
{% set active = 'offres' %}

{% block title %}{{ title }}{% endblock %}

{% block content %}
<div class="page-header">
  <div class="page-header-inner">
    <div class="breadcrumb">
      <a href="/">Accueil</a><span>›</span>
      <a href="/dashboard/offres">Offres</a><span>›</span>
      <span class="current">{{ offre ? 'Modifier' : 'Nouvelle offre' }}</span>
    </div>
    <h1>{{ offre ? 'Modifier ' ~ offre.title : 'Nouvelle offre' }}</h1>
  </div>
</div>

<div class="layout">
  <div class="main-content" style="max-width:640px; margin:0 auto;">
    <form action="{{ offre ? path('offres_edit', {'id': offre.id_offer}) : path('offres_create') }}"
          method="POST"
          class="form-offre">

      {# Intitulé #}
      <div class="form-group">
        <label>Intitulé *</label>
        <input type="text" name="title" value="{{ offre.title ?? '' }}" placeholder="Développeur Full-Stack">
        {% if errors.title %}
          <p class="error">{{ errors.title }}</p>
        {% endif %}
      </div>

      {# Description #}
      <div class="form-group">
        <label>Description</label>
        <textarea name="description" rows="4">{{ offre.description ?? '' }}</textarea>
      </div>

      {# Compétences #}
      <div class="form-group">
        <label>Compétences</label>
        <input type="text" name="skill" value="{{ offre.skill ?? '' }}" placeholder="PHP, JavaScript, MySQL">
      </div>

      {# Durée / Rémunération #}
      <div class="form-row">
        <div class="form-group">
          <label>Durée</label>
          <input type="text" name="duration" value="{{ offre.duration ?? '' }}" placeholder="6 mois">
        </div>
        <div class="form-group">
          <label>Rémunération</label>
          <input type="text" name="remuneration" value="{{ offre.remuneration ?? '' }}" placeholder="800 €/mois">
        </div>
      </div>

      {# Niveau / Type #}
      <div class="form-row">
        <div class="form-group">
          <label>Niveau</label>
          <input type="text" name="level" value="{{ offre.level ?? '' }}" placeholder="Bac+3">
        </div>
        <div class="form-group">
          <label>Type</label>
          <input type="text" name="type" value="{{ offre.type ?? '' }}" placeholder="Stage">
        </div>
      </div>

      {# Domaine #}
      <div class="form-group">
        <label>Domaine</label>
        <select name="id_domain">
          <option value="">— Aucun —</option>
          {% for d in domaines %}
            <option value="{{ d.id_domain }}" {{ (offre.id_domain ?? '') == d.id_domain ? 'selected' : '' }}>
              {{ d.name }}
            </option>
          {% endfor %}
        </select>
      </div>

      {# Entreprise #}
      <div class="form-group">
        <label>Entreprise</label>
        <select name="id_entreprise">
          <option value="">— Aucune —</option>
          {% for e in entreprises %}
            <option value="{{ e.id_entreprise }}" {{ (offre.id_entreprise ?? '') == e.id_entreprise ? 'selected' : '' }}>
              {{ e.name }}
            </option>
          {% endfor %}
        </select>
      </div>

      {# Boutons #}
      <div class="form-actions">
        <a href="{{ path('dashboard_offres') }}" class="btn-cancel">Annuler</a>
        <button type="submit" class="btn-submit">{{ offre ? 'Enregistrer' : 'Créer l\'offre' }}</button>
      </div>
    </form>
  </div>
</div>
{% endblock %}

{# Styles internes pour simplifier, à mettre en CSS réel #}
<style>
  .form-offre { background:#fff; border-radius:12px; padding:32px; display:flex; flex-direction:column; gap:20px; }
  .form-group { display:flex; flex-direction:column; gap:4px; }
  .form-row { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
  .form-group input, .form-group textarea, .form-group select { padding:10px 14px; border:1px solid #ddd; border-radius:8px; font-size:.95rem; width:100%; }
  .error { color:#e53e3e; font-size:.85rem; margin-top:4px; }
  .form-actions { display:flex; gap:12px; justify-content:flex-end; margin-top:8px; }
  .btn-cancel { padding:10px 24px; border-radius:8px; background:#eee; color:#333; text-decoration:none; font-weight:600; }
  .btn-submit { padding:10px 28px; border-radius:8px; background:#2563eb; color:#fff; border:none; font-weight:600; cursor:pointer; }
</style>