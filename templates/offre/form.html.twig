{% extends 'base.html.twig' %}
{% set active = 'offres' %}

{% block title %}{{ title }}{% endblock %}

{% block content %}
<div class="page-header">
  <div class="page-header-inner">
    <div class="breadcrumb">
      <a href="/">Accueil</a><span>›</span>
      <a href="/dashboard/offres">Offres</a><span>›</span>
      <span class="current">{{ offre ? 'Modifier' : 'Nouvelle offre' }}</span>
    </div>
    <h1>{{ (offre ? 'Modifier ' ~ offre.title : 'Nouvelle offre')|raw }}</h1>
  </div>
</div>

<div class="layout">
  <div class="main-content" style="max-width:640px; margin:0 auto;">
    <form action="{{ offre ? '/offres/' ~ offre.id_offer ~ '/edit' : '/offres/create' }}"
          method="POST"
          style="background:#fff; border-radius:12px; padding:32px; display:flex; flex-direction:column; gap:20px;">

      <div>
        <label style="font-weight:600; display:block; margin-bottom:6px;">Intitulé *</label>
        <input class="search-input" type="text" name="title"
               value="{{ offre.title ?? '' }}" placeholder="Développeur Full-Stack" style="width:100%;">
        {% if errors.title %}<p style="color:#e53e3e; font-size:.85rem; margin-top:4px;">{{ errors.title }}</p>{% endif %}
      </div>

      <div>
        <label style="font-weight:600; display:block; margin-bottom:6px;">Description</label>
        <textarea name="description" rows="4"
                  style="width:100%; border:1px solid #ddd; border-radius:8px; padding:10px 14px; font-size:.95rem; resize:vertical;">{{ offre.description ?? '' }}</textarea>
      </div>

      <div>
        <label style="font-weight:600; display:block; margin-bottom:6px;">Compétences</label>
        <input class="search-input" type="text" name="skill"
               value="{{ offre.skill ?? '' }}" placeholder="PHP, JavaScript, MySQL" style="width:100%;">
      </div>

      <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
        <div>
          <label style="font-weight:600; display:block; margin-bottom:6px;">Durée</label>
          <input class="search-input" type="text" name="duration"
                 value="{{ offre.duration ?? '' }}" placeholder="6 mois" style="width:100%;">
        </div>
        <div>
          <label style="font-weight:600; display:block; margin-bottom:6px;">Rémunération</label>
          <input class="search-input" type="text" name="remuneration"
                 value="{{ offre.remuneration ?? '' }}" placeholder="800 €/mois" style="width:100%;">
        </div>
      </div>

      <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
        <div>
          <label style="font-weight:600; display:block; margin-bottom:6px;">Niveau</label>
          <input class="search-input" type="text" name="level"
                 value="{{ offre.level ?? '' }}" placeholder="Bac+3" style="width:100%;">
        </div>
        <div>
          <label style="font-weight:600; display:block; margin-bottom:6px;">Type</label>
          <input class="search-input" type="text" name="type"
                 value="{{ offre.type ?? '' }}" placeholder="Stage" style="width:100%;">
        </div>
      </div>

      <div>
        <label style="font-weight:600; display:block; margin-bottom:6px;">Domaine</label>
        <select name="id_domain"
                style="width:100%; border:1px solid #ddd; border-radius:8px; padding:10px 14px; font-size:.95rem; background:#fff;">
          <option value="">— Aucun —</option>
          {% for d in domaines %}
            <option value="{{ d.id_domain }}" {{ (offre.id_domain ?? '') == d.id_domain ? 'selected' }}>
              {{ d.name }}
            </option>
          {% endfor %}
        </select>
      </div>

      <div>
        <label style="font-weight:600; display:block; margin-bottom:6px;">Entreprise</label>
        <select name="id_entreprise"
                style="width:100%; border:1px solid #ddd; border-radius:8px; padding:10px 14px; font-size:.95rem; background:#fff;">
          <option value="">— Aucune —</option>
          {% for e in entreprises %}
            <option value="{{ e.id_entreprise }}" {{ (offre.id_entreprise ?? '') == e.id_entreprise ? 'selected' }}>
              {{ e.name }}
            </option>
          {% endfor %}
        </select>
      </div>

      <div style="display:flex; gap:12px; justify-content:flex-end; margin-top:8px;">
        <a href="/dashboard/offres"
           style="padding:10px 24px; border-radius:8px; background:#eee; color:#333; text-decoration:none; font-weight:600;">
          Annuler
        </a>
        <button type="submit"
                style="padding:10px 28px; border-radius:8px; background:#2563eb; color:#fff; border:none; font-weight:600; cursor:pointer;">
          {{ offre ? 'Enregistrer' : 'Créer l\'offre' }}
        </button>
      </div>

    </form>
  </div>
</div>
{% endblock %}